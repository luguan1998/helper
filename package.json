{
  "name": "helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "客服助手:内部通讯软件(仅 text/picture)上的 Claude bot",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "marked": "^14.1.3",
    "marked-highlight": "^2.2.4",
    "puppeteer-core": "^23.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
